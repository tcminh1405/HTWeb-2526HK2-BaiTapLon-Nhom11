.after-header .has-account.outside .trans-item:not(.user_action) .dropdown-toggle.arrow-custom::after{font-size:0!important}
.custom_new_menu.top_footer_menu_wrapper li.menu-item>a{min-width: unset;width: max-content;width: fit-content;}
.messages.messages--status{display:none!important}
.slide-am-thuc>h1.dining-page-title{top: calc(50% - 100px);}
.slide-am-thuc .owl-theme .owl-dots .owl-dot span {display:none;}
body.path-phu-quoc .js-form-item.db-checkbox.js-form-type-checkbox {margin-left:unset!important;}
body.path-phu-quoc .js-form-item.db-checkbox.js-form-type-checkbox em {width:24px!important;height:24px!important;}
body.path-nam-hoi-an .section-resort-content .card .icon-like{position:absolute;display:block;right:10px;width:26px;height:26px;top:10px;padding:1px 5px;border-radius:50%;background-color:#fff;z-index:1}body.path-nha-trang .section-resort-content .card .icon-like{position:absolute;display:block;right:10px;width:26px;height:26px;top:10px;padding:1px 5px;border-radius:50%;background-color:#fff;z-index:1}body.path-nam-hoi-an .section-resort-content .card .icon-like>a{height:100%;display:flex;align-items:center;padding-top:3px}body.path-nha-trang .section-resort-content .card .icon-like>a{height:100%;display:flex;align-items:center;padding-top:3px}body.path-nam-hoi-an .section-resort-content .card .icon-like i{font-size:16px}body.path-nha-trang .section-resort-content .card .icon-like i{font-size:16px}body.path-nam-hoi-an .section-resort-content .card .icon-like i::before{color:#585858}body.path-nam-hoi-an .section-resort-content .card .action-unflag i::before{color:#e07a5f}
body.path-frontpage.vp-lock .after-header>#vp-booking-form{display:none}
#_book_hotel .reportrange span,.reportrange span[start]{white-space:nowrap}.vinpearl-golf-booking{position:relative}.vinwonders_playground .owl-carousel.owl-loaded{display: flex!important}.vp-room-choose .vp-calc .nice-number input{text-align: center;}
@media (max-width: 480px) {
#master-page .vpc-logo a img {width:100%}
}
body.user-logged-in{padding-top:100px}
body.user-logged-in:not(.toolbar-fixed):not(.insider-added) .after-header{margin-top:0!important}
@media (min-width:992px) {
body.user-logged-in.fixed-bs:not(.toolbar-fixed) .after-header{margin-top:-100px!important}
.block-hotel-wrapper>.tab-content, body.path-hotels #_destination .item_wrapper {padding:0}
#_destination .item_wrapper ul.nav-item {display:flex}
}
@media (max-width:992px){
.block-ht-custom.block-user-block .block-content>.user-block.logout .dropdown>.dropdown-toggle {
position: absolute;
left: 0;
width: 100%;
}
.block-ht-custom.block-user-block .block-content>.user-block.logout .dropdown>.dropdown-toggle::after {
opacity: 0 !important;
}
.block-ht-custom.block-user-block .block-content>.user-block{
position: relative;
}
}
.node-hotel #detail-news .card-box-title>h3>a{
display: -webkit-box !important;
-webkit-line-clamp: 3 !important;
}
.nav-item #brand-tab{display:none}
.banner-block .vp-values-block .item:nth-child(1) img {width:12px;height:16px}
.banner-block .vp-values-block .item:nth-child(2) img {width:17px;height:17px}
.banner-block .vp-values-block .item:nth-child(3) img {width:16px;height:16px}
.rd-slider .item-info .info-wrapper{flex-wrap: wrap;}
.convert-price-wrapper.detail-hotel{width:100%}
.destination-block .item-wrapper._3{height: 298px;overflow: hidden;}
.destination-block .item-wrapper._4{height: 250px;overflow: hidden;}
.banner-info .banner-cta a{background-position-x:calc(100% - 13px);}
.footer-wrapper .menu-tit{white-space:nowrap;}
.footer-wrapper .footer-below>.container .vp-social-links{display: flex;}
.exp-block .exp-item-des{-webkit-line-clamp: 2;}
.navbar-nav .nav-item.dropdown .dropdown-menu{border:0}
@media (min-width: 1200px) {
body:not(.path-frontpage) .dialog-off-canvas-main-canvas{padding-top:136px}
}
